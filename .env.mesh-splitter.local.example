# Environment template for local LAN deployment
# Copy to .env.mesh-splitter.local and fill secrets.

# Container image to run for LAN deployment
MESH_SPLITTER_IMAGE=ghcr.io/maliev-co-ltd/maliev.meshsplitter:main

# Optional local bind port
MESH_SPLITTER_HOST_PORT=3000

# Backend runtime secrets (minimum)
SESSION_SECRET=replace-with-long-random-string
SHOPIFY_APP_PROXY_SECRET=replace-with-app-proxy-secret-or-random

# Optional secrets/flags
SHOPIFY_WEBHOOK_SECRET=
CREDIT_STORE=memory
DATABASE_URL=
CORS_ALLOW_ORIGIN=https://mesh-splitter.local

# Required for private GHCR access on NAS
# Set this once in a local secret-safe file:
#   GHCR_USERNAME=<GitHub username>
#   GHCR_TOKEN=<Personal Access Token with read:packages>
#
# Optional if you prefer Docker CLI login instead of these env vars.
# Watchtower can also use mounted /root/.docker/config.json for GHCR.
GHCR_USERNAME=
GHCR_TOKEN=
