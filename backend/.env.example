PORT=3000
NODE_ENV=production
DATABASE_URL=postgres://user:password@host:5432/mesh_splitter
SHOPIFY_APP_PROXY_SECRET=replace-with-shopify-app-proxy-shared-secret
SHOPIFY_WEBHOOK_SECRET=replace-with-shopify-webhook-secret
SESSION_SECRET=replace-with-long-random-session-secret
FRONTEND_DIST_DIR=../frontend/dist
CORS_ALLOW_ORIGIN=https://your-store.myshopify.com
DEV_CUSTOMER_BYPASS=false
