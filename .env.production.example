NODE_ENV=production
PORT=3000
FRONTEND_DIST_DIR=/app/frontend/dist
DATABASE_URL=postgres://mesh_splitter:<password>@<host>:5432/mesh_splitter
CREDIT_STORE=datastore
GOOGLE_CLOUD_PROJECT=maliev-website
DATASTORE_NAMESPACE=mesh-splitter
SHOPIFY_APP_PROXY_SECRET=<shopify-app-client-secret>
SHOPIFY_WEBHOOK_SECRET=<shopify-webhook-secret>
SESSION_SECRET=<generate-with-openssl-rand-base64-48>
# Staff free-credit allowance. Customers whose Shopify email is on one of these
# domains get STAFF_FREE_GENERATIONS free exports/month instead of the default 3.
# Requires a Shopify Admin API token (custom app with read_customers scope) so
# the backend can resolve a logged-in customer's email by id.
STAFF_EMAIL_DOMAINS=maliev.com
STAFF_FREE_GENERATIONS=100
SHOPIFY_ADMIN_API_TOKEN=<custom-app-admin-api-token-with-read_customers>
VITE_MESH_API_BASE_URL=/api
VITE_CREDITS_ENFORCEMENT=required
VITE_SHOPIFY_STORE_DOMAIN=shop.maliev.com
